# Конфигурация AI-слоя (Этап 5). Скопируйте в .env и впишите ключ.
# Файл .env в .gitignore — ключ не попадает в git.

AI_API_KEY=
AI_BASE_URL=https://neuroapi.host/v1
AI_MODEL=claude-sonnet-4-5

# Без AI_API_KEY весь функционал этапов 0-4 работает как раньше,
# AI-функции отключаются с пояснением.

# Курс доллара к рублю для перевода стоимости прогона в рубли (необязательно).
# Стоимость меряется по балансу кабинета neuroapi; без курса показывается в $.
AI_USD_RUB=
